{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "battery"],

    "hyprland/workspaces": {
        "format": "{name}"
    },
    "clock": {
        "format": "{:%H:%M:%S}",
        "interval": 1
    },
    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTED"
    },
    "battery": {
        "format": "BAT {capacity}%",
        "interval": 20
    }
}
