[global]
    # Typography
    font = JetBrains Mono 11
    
    # Geometry (The Void)
    corner_radius = 0
    
    # Borders (Must be non-zero to see the sharp edge)
    frame_width = 2
    frame_color = "#ffffff"
    
    # Borders & Spacing
    frame_width = 2
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 15
    
    # Theming
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    separator_color = frame
    
    # Behavior
    sort = yes
    idle_threshold = 120
    markup = full
    format = "<b>%s</b>\n%b"
    word_wrap = yes

[urgency_low]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#313244"
    timeout = 3

[urgency_normal]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#89b4fa" # JetBrains blue accent matching your Waybar
    timeout = 5

[urgency_critical]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#f38ba8" # Critical red accent matching your Battery alert
    timeout = 0 # Keeps critical alerts on screen until manually clicked

