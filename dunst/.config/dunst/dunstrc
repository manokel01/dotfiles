[global]
    font = JetBrainsMono Nerd Font 10
    allow_markup = yes
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    width = 300
    height = 100
    offset = 10x10
    shrink = no
    transparency = 0
    notification_limit = 5
    idle_threshold = 120
    follow = mouse
    sticky_history = yes
    history_length = 20
    show_tips = yes
    line_height = 0
    padding = 8
    horizontal_padding = 8
    separator_color = frame
    separator_height = 2
    frame_width = 2
    frame_color = "#7aa2f7"
    corner_radius = 0

[urgency_low]
    background = "#24283b"
    foreground = "#c0caf5"
    timeout = 10

[urgency_normal]
    background = "#24283b"
    foreground = "#c0caf5"
    timeout = 10

[urgency_critical]
    background = "#24283b"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
