#!/bin/bash
DOTFILES_DIR="$HOME/dotfiles"

# 1. Physical Backup (Decoupled UI -> Vault)
# Added Walker to the sync logic
cp ~/.config/hypr/hyprland.conf "$DOTFILES_DIR/hypr/.config/hypr/hyprland.conf"
cp ~/.config/waybar/config.jsonc "$DOTFILES_DIR/waybar/.config/waybar/config.jsonc"
cp ~/.config/waybar/style.css "$DOTFILES_DIR/waybar/.config/waybar/style.css"
cp ~/.config/walker/config.toml "$DOTFILES_DIR/walker/.config/walker/config.toml"

# Sync new scripts (note.sh)
if [ -f "$HOME/.local/bin/note.sh" ]; then
    cp "$HOME/.local/bin/note.sh" "$DOTFILES_DIR/scripts/.local/bin/note.sh"
fi

# 2. Preparation for GitHub
cd "$DOTFILES_DIR" || exit 1
git add -A

if git diff --staged --quiet; then
    echo -e "\n--- VOID: NOTHING TO COMMIT ---"
    echo ""
    read -n 1 -s -r -p "Press any key to close..."
    exit 0
fi

# 3. The Interactive Prompt
echo "========================================"
echo "          NATIVE VOID SYNC              "
echo "========================================"
git status -s
echo "----------------------------------------"
echo "Enter commit description (or press Ctrl+C to abort):"
read -r COMMIT_MSG

if [ -z "$COMMIT_MSG" ]; then
    echo -e "\nAborted: Commit message cannot be empty."
    echo ""
    read -n 1 -s -r -p "Press any key to close..."
    exit 1
fi

# 4. The Truth Check
git commit -m "$COMMIT_MSG"

if git push origin main; then
    # Signal Waybar to turn the Git icon Green
    pkill -RTMIN+2 waybar
    echo -e "\n--- VOID: GITHUB SYNC SUCCESSFUL ---"
else
    echo -e "\n!!! VOID: GITHUB PUSH FAILED !!!"
    notify-send -u critical "Void Sync" "GitHub Push FAILED"
fi

# 5. The Audit Freeze
echo -e "\n========================================"
read -n 1 -s -r -p "Audit complete. Press any key to close this window..."
