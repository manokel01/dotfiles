#!/bin/bash
DOTFILES_DIR="$HOME/dotfiles"

# 1. Physical Backup
cp ~/.config/hypr/hyprland.conf "$DOTFILES_DIR/hypr/.config/hypr/hyprland.conf"
cp ~/.config/waybar/config.jsonc "$DOTFILES_DIR/waybar/.config/waybar/config.jsonc"
cp ~/.config/waybar/style.css "$DOTFILES_DIR/waybar/.config/waybar/style.css"

# 2. Preparation for GitHub
cd "$DOTFILES_DIR" || exit 1
git add -A

if git diff --staged --quiet; then
    echo -e "\n--- VOID: NOTHING TO COMMIT ---"
    exit 0
fi

# 3. The Interactive Prompt
echo "========================================"
echo "          NATIVE VOID SYNC              "
echo "========================================"
git status -s
echo "----------------------------------------"
echo "Enter commit description (or press Ctrl+C to abort):"
read -r COMMIT_MSG

[ -z "$COMMIT_MSG" ] && { echo "Aborted: Empty message."; exit 1; }

# 4. The Truth Check
git commit -m "$COMMIT_MSG"

if git push origin main; then
    killall -SIGUSR2 waybar
    echo -e "\n--- VOID: GITHUB SYNC SUCCESSFUL ---"
else
    echo -e "\n!!! VOID: GITHUB PUSH FAILED !!!"
    notify-send -u critical "Void Sync" "GitHub Push FAILED"
fi
